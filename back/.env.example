# Docker Compose publishes PostgreSQL on port 5433. Keep this port in sync with docker-compose.yml.
DATABASE_URL="postgresql://jobtracker:jobtracker_password@127.0.0.1:5433/jobtracker?schema=public"
# Dedicated local test database. Never point this at production or the normal dev database.
TEST_DATABASE_URL="postgresql://jobtracker:jobtracker_password@127.0.0.1:5433/peepss_security_test?schema=public"
JWT_SECRET="replace_me_with_a_real_secret"
PORT=4000
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"
OPENAI_API_KEY="replace_me_with_your_openai_api_key"
OPENAI_MODEL="replace_me_with_model_name"
ADMIN_EMAILS=""
ADMIN_PHONES=""
OTP_CODE_LENGTH=4
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
