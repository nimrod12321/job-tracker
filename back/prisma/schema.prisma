generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  applied
  HR
  technical
  rejected
  offer
}

model Job {
  id           String    @id @default(uuid())
  company      String
  position     String
  status       JobStatus @default(applied)
  wantedSalary Int       @default(0)
  location     String
  notes        String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs          Job[]
  resumeProfile ResumeProfile?
}

model ResumeProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName          String   @default("")
  targetRole        String   @default("")
  location          String   @default("")
  salaryExpectation Int      @default(0)
  skills            String   @default("")
  experienceText    String   @default("")
  resumeText        String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
