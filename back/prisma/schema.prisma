generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  applied
  HR
  technical
  rejected
  offer
}

enum JobPriority {
  low
  medium
  high
}

enum DiscoveryDecision {
  liked
  disliked
}

enum UserTrack {
  highTech
  restaurant
  restaurantOwner
}

enum RestaurantRole {
  waiter
  bartender
  host
  floorManager
  cook
}

enum RestaurantJobKind {
  draft
  posted
}

enum RestaurantApplicationStatus {
  applied
  selected
  rejected
}

enum CandidateLeadStatus {
  new
  contacted
  relevant
  rejected
}

model Job {
  id             String      @id @default(uuid())
  company        String
  position       String
  status         JobStatus   @default(applied)
  wantedSalary   Int         @default(0)
  location       String
  notes          String      @default("")
  jobDescription String      @default("")
  jobUrl         String      @default("")
  companyUrl     String      @default("")
  source         String      @default("")
  priority       JobPriority @default(medium)
  dateApplied    DateTime?
  salaryMin      Int         @default(0)
  salaryMax      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  analysis JobAnalysis?
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  track        UserTrack @default(highTech)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  jobs                    Job[]
  resumeProfile           ResumeProfile?
  discoveryDecisions      JobDiscoveryDecision[]
  restaurantWorkerProfile RestaurantWorkerProfile?
  restaurantOwnerProfile  RestaurantOwnerProfile?
  restaurantApplications  RestaurantApplication[]
}

model ResumeProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName          String   @default("")
  targetRole        String   @default("")
  location          String   @default("")
  salaryExpectation Int      @default(0)
  skills            String   @default("")
  experienceText    String   @default("")
  resumeText        String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model JobAnalysis {
  id                 String   @id @default(uuid())
  jobId              String   @unique
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  matchScore         Int
  fitSummary         String
  strengths          String
  missingSkills      String
  resumeSuggestions  String
  interviewQuestions String
  recruiterMessage   String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model JobDiscoveryDecision {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  externalId String
  jobUrl     String @default("")
  company    String
  position   String
  location   String @default("")
  source     String

  jobDescription  String @default("")
  salaryText      String @default("")
  estimatedSalary String @default("")
  summary         String @default("")
  fitScore        Int    @default(0)
  fitReason       String @default("")

  decision DiscoveryDecision

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, source, externalId])
  @@index([userId])
  @@index([userId, decision])
  @@index([userId, jobUrl])
}

model RestaurantWorkerProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName       String           @default("")
  phoneNumber    String           @default("")
  location       String           @default("")
  wantedRoles    RestaurantRole[] @default([])
  experienceText String           @default("")
  availability   String           @default("")
  age            Int              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RestaurantJob {
  id String @id @default(uuid())

  restaurantName  String
  role            RestaurantRole
  location        String
  area            String         @default("")
  description     String         @default("")
  requirements    String         @default("")
  shiftInfo       String         @default("")
  contactPhone    String         @default("")
  contactWhatsapp String         @default("")
  kind            RestaurantJobKind @default(draft)
  isActive        Boolean        @default(true)

  ownerProfileId String?
  ownerProfile   RestaurantOwnerProfile? @relation(fields: [ownerProfileId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications RestaurantApplication[]

  @@index([role])
  @@index([location])
  @@index([kind])
  @@index([isActive])
  @@index([ownerProfileId])
}

model RestaurantOwnerProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantName String @default("")
  contactPerson  String @default("")
  phoneNumber    String @default("")
  whatsappNumber String @default("")
  city           String @default("")
  street         String @default("")
  description    String @default("")
  slug           String? @unique

  jobs  RestaurantJob[]
  leads RestaurantCandidateLead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RestaurantCandidateLead {
  id String @id @default(uuid())

  ownerProfileId String
  ownerProfile   RestaurantOwnerProfile @relation(fields: [ownerProfileId], references: [id], onDelete: Cascade)

  fullName       String
  phoneNumber    String
  wantedRoles    RestaurantRole[]
  experienceText String           @default("")
  availability   String           @default("")
  age            Int?
  source         String           @default("qr")
  status         CandidateLeadStatus @default(new)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerProfileId])
  @@index([phoneNumber])
  @@index([status])
  @@index([createdAt])
}

model RestaurantApplication {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantJobId String
  restaurantJob   RestaurantJob @relation(fields: [restaurantJobId], references: [id], onDelete: Cascade)

  status RestaurantApplicationStatus @default(applied)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, restaurantJobId])
  @@index([userId])
  @@index([restaurantJobId])
}
