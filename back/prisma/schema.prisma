generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  applied
  HR
  technical
  rejected
  offer
}

enum JobPriority {
  low
  medium
  high
}

enum DiscoveryDecision {
  liked
  disliked
}

model Job {
  id             String      @id @default(uuid())
  company        String
  position       String
  status         JobStatus   @default(applied)
  wantedSalary   Int         @default(0)
  location       String
  notes          String      @default("")
  jobDescription String      @default("")
  jobUrl         String      @default("")
  companyUrl     String      @default("")
  source         String      @default("")
  priority       JobPriority @default(medium)
  dateApplied    DateTime?
  salaryMin      Int         @default(0)
  salaryMax      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  analysis JobAnalysis?
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs               Job[]
  resumeProfile      ResumeProfile?
  discoveryDecisions JobDiscoveryDecision[]
}

model ResumeProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName          String   @default("")
  targetRole        String   @default("")
  location          String   @default("")
  salaryExpectation Int      @default(0)
  skills            String   @default("")
  experienceText    String   @default("")
  resumeText        String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model JobAnalysis {
  id                 String   @id @default(uuid())
  jobId              String   @unique
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  matchScore         Int
  fitSummary         String
  strengths          String
  missingSkills      String
  resumeSuggestions  String
  interviewQuestions String
  recruiterMessage   String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model JobDiscoveryDecision {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  externalId String
  jobUrl     String @default("")
  company    String
  position   String
  location   String @default("")
  source     String

  jobDescription  String @default("")
  salaryText      String @default("")
  estimatedSalary String @default("")
  summary         String @default("")
  fitScore        Int    @default(0)
  fitReason       String @default("")

  decision DiscoveryDecision

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, source, externalId])
  @@index([userId])
  @@index([userId, decision])
  @@index([userId, jobUrl])
}
